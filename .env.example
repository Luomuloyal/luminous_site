# 开发环境直接连接本地启动的后端 (通常是3030端口)
VITE_API_BASE_URL=http://localhost:3030

# 前端部署基础路径
# GitHub Pages 仓库 luminous_site 推荐: /luminous_site/
# 当前你的服务器地址 https://devluo.com/luminous/ 推荐: /luminous/
VITE_PUBLIC_BASE=/luminous_site/

# 如果前后端一起托管部署（由后端直接 serve dist），可以直接保留为空，前端会自动使用相对路径。
# VITE_API_BASE_URL=

# 如果前后端分离部署 (如前端 Vercel + 后端云服务)，则需要填上后端的公开域名
# VITE_API_BASE_URL=https://api.yourdomain.com
